@model SV22T1020375.Models.Partner.ChangeCustomerPasswordViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Đổi mật khẩu khách hàng";
}

<div class="box box-primary">
    <div class="box-header with-border">
        <h3 class="box-title">Đổi mật khẩu khách hàng</h3>
    </div>
    <div class="box-body">
        <!-- Thông tin khách hàng -->
        <div class="form-group">
            <h4><i class="fa fa-user"></i> Thông tin khách hàng</h4>
            <dl class="dl-horizontal">
                <dt>Tên khách hàng</dt>
                <dd>@Model.CustomerName</dd>
                <dt>Email</dt>
                <dd>@Model.Email</dd>
                <dt>Trạng thái</dt>
                <dd>
                    @if (Model.IsLocked)
                    {
                        <span class="label label-danger">Đang bị khóa</span>
                    }
                    else
                    {
                        <span class="label label-success">Đang hoạt động</span>
                    }
                </dd>
            </dl>
        </div>

        <hr />

        <!-- Form đổi mật khẩu -->
        <div class="form-group">
            <h4><i class="fa fa-lock"></i> Thông tin mật khẩu</h4>
            <form asp-action="ChangePassword" method="post">
                <input type="hidden" asp-for="CustomerID" />

                <div class="form-group">
                    <label asp-for="NewPassword"></label>
                    <input asp-for="NewPassword" type="password" class="form-control" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword"></label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="box-footer">
                    <button type="submit" class="btn btn-primary btn-flat">
                        <i class="fa fa-key"></i> Đổi mật khẩu
                    </button>
                    <a asp-action="Index" class="btn btn-default btn-flat">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}