@model SV22T1020375.Models.Common.PagedResult<SV22T1020375.Models.HR.Employee>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> nhân viên
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th class="text-center" style="width:70px;">Ảnh</th>
                    <th>Họ tên</th>
                    <th>Ngày sinh</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems == null || !Model.DataItems.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted">Không có nhân viên nào</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="@Url.Content($"~/images/employees/{(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)}")"
                                     alt="@item.FullName"
                                     style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;"
                                     onerror="this.onerror=null; this.src='@Url.Content("~/images/employees/nophoto.png")';" />
                            </td>
                            <td>@item.FullName</td>
                            <td>@item.BirthDate?.ToString("dd/MM/yyyy")</td>
                            <td>@item.Phone</td>
                            <td>@item.Email</td>
                            <td>@item.Address</td>
                            <td class="text-center">
                                @if (item.IsWorking == true)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Nghỉ việc</span>
                                }
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="~/Employee/Edit/@item.EmployeeID" class="btn btn-sm btn-primary" title="Cập nhật">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Employee/Delete/@item.EmployeeID" class="btn btn-sm btn-danger" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        <ul class="pagination justify-content-center">
            @foreach (var p in Model.GetDisplayPages())
            {
                if (p.IsCurrent)
                {
                    <li class="page-item active">
                        <a class="page-link">@p.Page</a>
                    </li>
                }
                else if (p.IsEllipsis)
                {
                    <li class="page-item">
                        <a class="page-link">....</a>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="javascript:;"
                           onclick="paginationSearch(null, document.getElementById('formSearch'), @p.Page)">
                            @p.Page
                        </a>
                    </li>
                }
            }
        </ul>
    </div>
</div>