@model SV22T1020375.Models.HR.Employee
@{
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-person-badge me-2"></i>
                    Thông tin nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" enctype="multipart/form-data" action="~/Employee/SaveData">
                    <input type="hidden" asp-for="EmployeeID" />
                    <input type="hidden" asp-for="Photo" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Họ và tên</label>
                        <div class="col-sm-5">
                            <input type="text"
                                   class="form-control"
                                   asp-for="FullName"
                                   placeholder="Nhập họ và tên"
                                   autofocus />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                        <label class="col-sm-2 col-form-label text-end">Ngày sinh</label>
                        <div class="col-sm-2">
                            <input type="date"
                                   class="form-control"
                                   asp-for="BirthDate" />
                            <span asp-validation-for="BirthDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Địa chỉ</label>
                        <div class="col-sm-9">
                            <textarea class="form-control"
                                      asp-for="Address"
                                      rows="3"
                                      placeholder="Nhập địa chỉ"></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Điện thoại</label>
                        <div class="col-sm-2">
                            <input type="tel"
                                   class="form-control"
                                   asp-for="Phone"
                                   placeholder="Nhập số điện thoại" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                        <label class="col-sm-1 col-form-label text-end">Email</label>
                        <div class="col-sm-6">
                            <input type="email"
                                   class="form-control"
                                   asp-for="Email"
                                   placeholder="Nhập email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="file"
                                   name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   data-img-preview="imgPreview"
                                   onchange="previewImage(this)" />

                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="~/images/employees/@(string.IsNullOrEmpty(Model?.Photo) ? "nophoto.png" : Model.Photo)"
                                     class="img-thumbnail"
                                     style="max-height: 150px;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="IsWorking"
                                       name="IsWorking"
                                       value="true"
                                       @(Model != null && Model.IsWorking == true ? "checked" : "") />
                                <input type="hidden" name="IsWorking" value="false" />
                                <label class="form-check-label" for="IsWorking">
                                    Đang làm việc
                                </label>
                            </div>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>