@model ProductSearchInput
@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <form id="formSearch"
                      method="get"
                      action="~/Order/SearchProduct"
                      data-target="searchResult"
                      onsubmit="paginationSearch(event, this, 1)">

                    <div class="input-group">

                        <input type="hidden" asp-for="PageSize" />
                        <input type="hidden" asp-for="CategoryID" />
                        <input type="hidden" asp-for="SupplierID" />
                        <input type="hidden" asp-for="MinPrice" />
                        <input type="hidden" asp-for="MaxPrice" />

                        <input class="form-control"
                               asp-for="SearchValue"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                        <button class="btn btn-primary">

                            <i class="bi bi-search"></i>

                        </button>
                    </div>
                </form>

                <div id="searchResult"></div>
            </div>
            <div class="card-footer">
            </div>
        </div>
    </div>

    <div class="col-8">
        <div class="row">
            <div class="col-12" id="cart">
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person"></i>
                            Thông tin khách hàng & nơi giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        <form method="post" onsubmit="createOrder(event,this)">
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Khách hàng</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="customerID">
                                        <option value="0">-- Chọn khách hàng --</option>
                                        @if (ViewBag.Customers != null)
                                        {
                                            foreach (var item in ViewBag.Customers)
                                            {
                                                <option value="@item.CustomerID">@item.CustomerName</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="province" asp-items="await SelectListHelper.Provinces()">
                                        <option value="">-- Chọn Tỉnh/thành giao hàng --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Địa chỉ</label>
                                <div class="col-md-10">
                                    <textarea class="form-control" name="address"></textarea>
                                </div>
                            </div>

                            <div class="text-end">
                                <button class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i>
                                    Lập đơn hàng
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
            showCart();
        });


        function showCart() {
            fetch('/Order/ShowCart', {
                method: 'GET'
            })
            .then(function (response) {
                if (!response.ok) {
                    throw new Error('Request failed');
                }
                return response.text();
            })
            .then(function (data) {
                document.getElementById('cart').innerHTML = data;
            })
            .catch(function () {
                document.getElementById('cart').innerHTML = 'Không thể tải giỏ hàng.';
            });
        }

        function addCartItem(event, form) {
            if (event) {
                event.preventDefault();
            }

            var formData = new FormData(form);

            fetch('/Order/AddCartItem', {
                method: 'POST',
                body: formData
            })
            .then(function (response) {
                if (!response.ok) {
                    throw new Error('Request failed');
                }
                return response.json();
            })
            .then(function (res) {
                if (res.code === 0) {
                    alert(res.message);
                } else {
                    showCart();
                }
            })
            .catch(function () {
                alert('Có lỗi xảy ra khi gửi dữ liệu.');
            });
        }

        function deleteCartItem(productID) {
            var formData = new FormData();
            formData.append('productID', productID);

            fetch('/Order/DeleteCartItem', {
                method: 'POST',
                body: formData
            })
            .then(function (response) {
                if (!response.ok) {
                    throw new Error('Request failed');
                }
                showCart();
            })
            .catch(function () {
                alert('Có lỗi xảy ra khi xóa sản phẩm khỏi giỏ hàng.');
            });
        }
        function clearCart() {
            fetch('/Order/ClearCart', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(function (response) {
                if (!response.ok) {
                    throw new Error('Request failed');
                }
                return response.json(); // nếu API không trả JSON thì có thể bỏ dòng này
            })
            .then(function () {
                showCart();
            })
            .catch(function () {
                alert('Có lỗi xảy ra khi xóa giỏ hàng.');
            });
        }


            function updateCartItem(event, form) {
            if (event) event.preventDefault();

            var formData = new FormData(form);

            fetch('/Order/UpdateCartItem', {
                method: 'POST',
                body: formData
            })
            .then(function (response) {
                if (!response.ok) throw new Error('Request failed');
                return response.json();
            })
            .then(function (res) {
                if (res.code === 0) {
                    alert(res.message);
                } else {
                    closeModalByForm(form);
                    showCart();
                }
            })
            .catch(function () {
                alert('Có lỗi xảy ra khi cập nhật giỏ hàng.');
            });
        }


         function createOrder(event, form) {
            // Ngăn submit mặc định
            event.preventDefault();

            const formData = new FormData(form);

            fetch('/Order/CreateOrder', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Lỗi khi gọi API');
                }
                return response.json(); // { code, message }
            })
            .then(data => {
                if (data.code === 0) {
                    // Hiển thị lỗi
                    alert(data.message);
                } else {
                    // Chuyển hướng sang trang chi tiết đơn hàng
                    window.location.href = `/Order/Detail/${data.code}`;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Có lỗi xảy ra khi tạo đơn hàng!');
            });
        }
    </script>
}