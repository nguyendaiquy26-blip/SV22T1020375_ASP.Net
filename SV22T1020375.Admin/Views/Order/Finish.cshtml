@model SV22T1020375.Models.Sales.OrderViewInfo
@{
    Layout = null;
}
<div class="modal-header text-bg-success">
    <strong class="modal-title">
        Xác nhận đơn hàng thành công
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    <form method="post" action="~/Order/Finish/@Model.OrderID" id="formFinish">
        <div class="alert alert-success d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            Bạn có chắc chắn xác nhận đơn hàng này đã được giao thành công?
        </div>
    </form>
</div>

<div class="modal-footer">
    <button type="submit" class="btn btn-primary" form="formFinish">
        <i class="bi bi-check"></i> Chấp nhận
    </button>
    <button type="button"
            class="btn btn-secondary"
            data-bs-dismiss="modal">
        Đóng
    </button>
</div>