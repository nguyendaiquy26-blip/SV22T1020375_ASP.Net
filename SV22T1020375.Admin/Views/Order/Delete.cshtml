@model SV22T1020375.Models.Sales.OrderViewInfo
@{
    Layout = null;
}
<div class="modal-header text-bg-danger">
    <strong class="modal-title">
        Xóa đơn hàng
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    <div class="alert alert-danger d-flex align-items-center">
        <i class="bi bi-info-circle me-2"></i>
        Bạn có chắc chắn muốn xóa đơn hàng này không?
    </div>

    <dl class="row mb-0">
        <dt class="col-sm-4">Mã đơn hàng</dt>
        <dd class="col-sm-8">@Model.OrderID</dd>

        <dt class="col-sm-4">Khách hàng</dt>
        <dd class="col-sm-8">@Model.CustomerName</dd>

        <dt class="col-sm-4">Thời điểm đặt</dt>
        <dd class="col-sm-8">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</dd>

        <dt class="col-sm-4">Địa chỉ giao</dt>
        <dd class="col-sm-8">@Model.DeliveryAddress</dd>
    </dl>
</div>

<div class="modal-footer">
    <form method="post" action="~/Order/DeleteData/@Model.OrderID">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check"></i> Chấp nhận
        </button>
    </form>
    <button type="button"
            class="btn btn-secondary"
            data-bs-dismiss="modal">
        Đóng
    </button>
</div>