@model SV22T1020375.Models.Sales.OrderViewInfo
@{
    Layout = null;
}
<div class="modal-header text-bg-warning">
    <strong class="modal-title">
        Xác nhận hủy đơn hàng
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    <form method="post" action="~/Order/Cancel/@Model.OrderID" id="formCancel">
        <div class="alert alert-warning d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            Bạn có thực sự muốn hủy đơn hàng này hay không?
        </div>
    </form>
</div>

<div class="modal-footer">
    <button type="submit" class="btn btn-primary" form="formCancel">
        <i class="bi bi-check"></i> Chấp nhận
    </button>
    <button type="button"
            class="btn btn-secondary"
            data-bs-dismiss="modal">
        Đóng
    </button>
</div>