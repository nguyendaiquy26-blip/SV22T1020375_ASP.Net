@model SV22T1020375.Models.Sales.OrderSearchInput
@{
    ViewBag.Title = "Quản lý Đơn hàng";
}

@section PageToolBar {
    <a href="~/Order/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Lập đơn hàng mới
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch"
              method="get"
              action="~/Order/Search"
              data-target="searchResult"
              onsubmit="paginationSearch(event, this, 1)">

            <input type="hidden" asp-for="PageSize" />

            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Trạng thái đơn hàng</label>
                    <select asp-for="Status" class="form-select">
                        <option value="0">-- Tất cả --</option>
                        <option value="1">Đơn hàng vừa tạo</option>
                        <option value="2">Đơn hàng đã được duyệt</option>
                        <option value="3">Đơn hàng đang được vận chuyển</option>
                        <option value="4">Đơn hàng đã hoàn tất</option>
                        <option value="-1">Đơn hàng đã bị hủy</option>
                        <option value="-2">Đơn hàng bị từ chối</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Thời gian lập đơn hàng</label>
                    <div class="input-group">
                        <input type="text"
                               class="form-control date-picker"
                               asp-for="DateFrom"
                               placeholder="Từ ngày..." />
                        <span class="input-group-text">-</span>
                        <input type="text"
                               class="form-control date-picker"
                               asp-for="DateTo"
                               placeholder="...đến ngày" />
                    </div>
                </div>

                <div class="col-md-5">
                    <label class="form-label">Tên khách hàng / địa chỉ giao hàng</label>
                    <div class="input-group">
                        <input type="text"
                               class="form-control"
                               asp-for="SearchValue"
                               placeholder="Tên khách hàng..."
                               autofocus />
                        <button type="submit" class="btn btn-info d-flex align-items-center">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="searchResult"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
        });
    </script>
}