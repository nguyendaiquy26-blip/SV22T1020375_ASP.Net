@model SV22T1020375.Models.Sales.OrderDetailViewInfo
@{
    Layout = null;
}
<div class="modal-header">
    <strong class="modal-title">
        Cập nhật mặt hàng trong đơn hàng
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    <form method="post"
          action="~/Order/SaveDetail"
          id="formEditDetail"
          class="container-fluid"
          onsubmit="saveDetail(event, this)">

        <input type="hidden" name="orderID" value="@Model.OrderID" />
        <input type="hidden" name="productID" value="@Model.ProductID" />

        <div class="row">
            <div class="col-md-8">
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Mặt hàng
                    </label>
                    <div class="col-sm-8">
                        <input type="text"
                               class="form-control-plaintext fw-bold"
                               value="@Model.ProductName"
                               readonly>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Số lượng
                    </label>
                    <div class="col-sm-5">
                        <input type="number"
                               name="quantity"
                               class="form-control text-end"
                               min="1"
                               required
                               value="@Model.Quantity">
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Đơn giá
                    </label>
                    <div class="col-sm-5">
                        <input type="text"
                               name="salePrice"
                               class="form-control text-end"
                               required
                               value="@Model.SalePrice">
                    </div>
                </div>
            </div>

            <div class="col-md-4 text-end">
                <img src="/images/products/@Model.Photo"
                     alt="@Model.ProductName"
                     class="img-thumbnail"
                     style="max-height:180px">
            </div>
        </div>
    </form>
</div>

<div class="modal-footer">
    <button type="submit" class="btn btn-primary" form="formEditDetail">
        Cập nhật
    </button>
    <button type="button"
            class="btn btn-secondary"
            data-bs-dismiss="modal">
        Đóng
    </button>
</div>