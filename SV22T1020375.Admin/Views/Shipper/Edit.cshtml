@model SV22T1020375.Models.Partner.Shipper
@{
    ViewBag.Title = ViewBag.Title ?? "Cập nhật đơn vị vận chuyển";
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Shipper" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-bicycle me-2"></i>
                    Thông tin đơn vị vận chuyển
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" action="~/Shipper/SaveData">
                    <input type="hidden" asp-for="ShipperID" />

                    <div class="mb-3">
                        <label class="form-label" asp-for="ShipperName">Tên đơn vị vận chuyển</label>
                        <input type="text"
                               class="form-control"
                               asp-for="ShipperName"
                               placeholder="Nhập tên đơn vị vận chuyển"
                               autofocus />
                        <span asp-validation-for="ShipperName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Phone">Điện thoại</label>
                        <input type="tel"
                               class="form-control"
                               asp-for="Phone"
                               placeholder="Nhập số điện thoại" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>