@model SV22T1020375.Models.Catalog.Product
@{
    ViewBag.Title = "Xóa mặt hàng";
}

@section PageToolBar {
    @if (ViewBag.AllowDelete)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i> Xóa
        </button>
    }
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger fw-bold">
                    <i class="bi bi-exclamation-triangle me-2"></i> Xác nhận xóa mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formDelete" method="post" action="~/Product/Delete/@Model.ProductID">

                    @if (ViewBag.AllowDelete)
                    {
                        <div class="alert alert-danger d-flex align-items-center">
                            <i class="bi bi-exclamation-circle-fill me-2 fs-5"></i>
                            <div>
                                Bạn có chắc chắn muốn xóa mặt hàng <strong>@Model.ProductName</strong> không? Hành động này không thể hoàn tác.
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                            <div>
                                Mặt hàng này <strong>không thể xóa</strong> vì đã có dữ liệu liên quan (ví dụ: đã nằm trong đơn hàng, có thư viện ảnh hoặc thuộc tính đính kèm...).
                            </div>
                        </div>
                    }

                    <div class="row mt-4">
                        <div class="col-md-8">
                            <dl class="row mb-0">
                                <dt class="col-sm-4 text-muted">Tên mặt hàng</dt>
                                <dd class="col-sm-8 fw-bold">@Model.ProductName</dd>

                                <dt class="col-sm-4 text-muted">Mã loại hàng</dt>
                                <dd class="col-sm-8">@Model.CategoryID</dd>

                                <dt class="col-sm-4 text-muted">Mã nhà cung cấp</dt>
                                <dd class="col-sm-8">@Model.SupplierID</dd>

                                <dt class="col-sm-4 text-muted">Đơn vị tính</dt>
                                <dd class="col-sm-8">@Model.Unit</dd>

                                <dt class="col-sm-4 text-muted">Giá bán</dt>
                                <dd class="col-sm-8 text-danger fw-bold">@Model.Price.ToString("N0") đ</dd>

                                <dt class="col-sm-4 text-muted">Trạng thái</dt>
                                <dd class="col-sm-8">
                                    @if (Model.IsSelling)
                                    {
                                        <span class="badge bg-success">Đang bán</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Ngừng bán</span>
                                    }
                                </dd>

                                <dt class="col-sm-4 text-muted">Mô tả</dt>
                                <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.ProductDescription) ? "Không có mô tả" : Model.ProductDescription)</dd>
                            </dl>
                        </div>

                        <div class="col-md-4 text-end">
                            <img src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                 class="img-fluid img-thumbnail shadow-sm"
                                 alt="Ảnh mặt hàng"
                                 style="max-height: 220px; object-fit: cover;" />
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>