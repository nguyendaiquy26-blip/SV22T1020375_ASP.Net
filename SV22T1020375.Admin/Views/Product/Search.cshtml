@model SV22T1020375.Models.Common.PagedResult<SV22T1020375.Models.Catalog.Product>

@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> mặt hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th style="width:80px;">Ảnh</th>
                    <th>Mặt hàng</th>
                    <th style="width:120px;">Đơn vị</th>
                    <th style="width:120px;">Giá</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:120px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems == null || !Model.DataItems.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">
                            Không có mặt hàng nào
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="@Url.Content(string.IsNullOrEmpty(item.Photo) ? "~/images/products/nophoto.png" : $"~/images/products/{item.Photo}")"
                                     class="img-thumbnail"
                                     style="width:60px;height:60px;object-fit:cover;"
                                     alt="@item.ProductName" />
                            </td>
                            <td>
                                <strong>@item.ProductName</strong><br />
                                <small class="text-muted">@item.ProductDescription</small>
                            </td>
                            <td>@item.Unit</td>
                            <td class="text-end">@item.Price.ToString("N0")</td>
                            <td class="text-center">
                                @if (item.IsSelling)
                                {
                                    <span class="badge bg-success">Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Ngừng bán</span>
                                }
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="~/Product/Detail/@item.ProductID" class="btn btn-sm btn-info" title="Chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="~/Product/Edit/@item.ProductID" class="btn btn-sm btn-primary" title="Cập nhật">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Product/Delete/@item.ProductID" class="btn btn-sm btn-danger" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        <ul class="pagination justify-content-center mb-0">
            @foreach (var p in Model.GetDisplayPages())
            {
                if (p.IsCurrent)
                {
                    <li class="page-item active">
                        <a class="page-link">@p.Page</a>
                    </li>
                }
                else if (p.IsEllipsis)
                {
                    <li class="page-item">
                        <a class="page-link">....</a>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="javascript:;"
                           onclick="paginationSearch(null, document.getElementById('formSearch'), @p.Page)">
                            @p.Page
                        </a>
                    </li>
                }
            }
        </ul>
    </div>
</div>