@model SV22T1020375.Models.Catalog.ProductSearchInput

@{
    ViewBag.Title = "Quản lý Mặt hàng";
}

@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        <strong>Thành công!</strong> @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="card mb-3 shadow-sm border-0">
    <div class="card-body">
        <form id="formSearch"
              method="get"
              action="~/Product/Search"
              data-target="searchResult"
              onsubmit="paginationSearch(event, this, 1)">

            <input type="hidden" asp-for="PageSize" />

            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select class="form-select" asp-for="CategoryID" asp-items="ViewBag.Categories">
                        <option value="">-- Tất cả --</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Nhà cung cấp</label>
                    <select class="form-select" asp-for="SupplierID" asp-items="ViewBag.Suppliers">
                        <option value="">-- Tất cả --</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        <input type="text"
                               class="form-control money-input"
                               asp-for="MinPrice"
                               placeholder="Từ" />
                        <span class="input-group-text">-</span>
                        <input type="text"
                               class="form-control money-input"
                               asp-for="MaxPrice"
                               placeholder="Đến" />
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input type="text"
                               class="form-control"
                               asp-for="SearchValue"
                               placeholder="Tên mặt hàng..."
                               autofocus />
                        <button type="submit" class="btn btn-info d-flex align-items-center text-white">
                            <i class="bi bi-search me-1"></i> Tìm kiếm
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="searchResult"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Load dữ liệu bảng ngay khi vào trang
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
        });
    </script>
}