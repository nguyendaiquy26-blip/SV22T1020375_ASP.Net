@model SV22T1020375.Models.Catalog.ProductPhoto

<div class="card card-primary card-outline shadow-sm">
    <div class="card-header">
        <h5 class="card-title">@ViewBag.Title</h5>
    </div>
    <div class="card-body">
        <form action="~/Product/SavePhoto" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="ProductID" />
            <input type="hidden" asp-for="PhotoID" />
            <input type="hidden" asp-for="Photo" />

            <div class="mb-3">
                <label class="form-label fw-bold">Chọn ảnh upload:</label>
                <input type="file" class="form-control" name="uploadPhoto" accept="image/*" onchange="document.getElementById('previewPhoto').src = window.URL.createObjectURL(this.files[0])" />
                <div class="mt-3">
                    <img id="previewPhoto" src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)" class="img-thumbnail" style="max-height: 200px;" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả ảnh:</label>
                <input type="text" class="form-control" asp-for="Description" autofocus />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Thứ tự hiển thị:</label>
                <input type="number" class="form-control" asp-for="DisplayOrder" min="1" />
                <span asp-validation-for="DisplayOrder" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input class="form-check-input" type="checkbox" asp-for="IsHidden" />
                <label class="form-check-label fw-bold">Ẩn ảnh này (Không hiển thị ra web)</label>
            </div>

            <div class="text-end">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Lưu dữ liệu</button>
                <a href="~/Product/Edit/@Model.ProductID" class="btn btn-secondary">Hủy bỏ</a>
            </div>
        </form>
    </div>
</div>