@model IEnumerable<SV22T1020375.Models.Catalog.ProductAttribute>

<div class="card mb-4 border-info">
    <div class="card-header bg-info text-white">
        <h5 class="card-title mb-0"><i class="bi bi-list-ul me-2"></i> Thuộc tính sản phẩm</h5>
    </div>
    <div class="card-body">
        <a href="~/Product/CreateAttribute/@ViewBag.ProductID" class="btn btn-success mb-3">
            <i class="bi bi-plus-circle"></i> Thêm thuộc tính
        </a>
        <div class="table-responsive p-0">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Tên thuộc tính</th>
                        <th>Giá trị</th>
                        <th class="text-center">Thứ tự</th>
                        <th class="text-center" style="width:120px">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.AttributeName</td>
                                <td>@item.AttributeValue</td>
                                <td class="text-center">@item.DisplayOrder</td>
                                <td class="text-center">
                                    <a href="~/Product/EditAttribute/@ViewBag.ProductID?attribute=@item.AttributeID" class="btn btn-sm btn-primary"><i class="bi bi-pencil-square"></i></a>
                                    <a href="~/Product/DeleteAttribute/@ViewBag.ProductID?attribute=@item.AttributeID" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa thuộc tính này?')"><i class="bi bi-trash"></i></a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center text-muted py-3">Chưa có thuộc tính nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>