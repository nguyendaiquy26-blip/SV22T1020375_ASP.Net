@using SV22T1020375.Models.Sales
@model IEnumerable<SV22T1020375.Models.Sales.OrderViewInfo>
@{
    ViewBag.Title = "Đơn hàng của tôi";
}

<div class="container mt-5 mb-5">
    <h3 class="mb-4 text-danger"><i class="fa fa-list-alt"></i> Quản lý đơn hàng</h3>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle text-center mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Nơi giao</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-danger">#@item.OrderID</td>
                                <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-start">@item.DeliveryProvince</td>
                                <td>
                                    @if (item.Status == OrderStatusEnum.New)
                                    {
                                        <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                    }
                                    else if (item.Status == OrderStatusEnum.Accepted)
                                    {

                                        <span class="badge bg-info text-dark">Đã duyệt</span>
                                    }
                                    else if (item.Status == OrderStatusEnum.Shipping)
                                    {

                                        <span class="badge bg-primary">Đang giao</span>
                                    }
                                    else if (item.Status == OrderStatusEnum.Completed)
                                    {

                                        <span class="badge bg-success">Hoàn tất</span>
                                    }
                                    else if (item.Status == OrderStatusEnum.Rejected || item.Status == OrderStatusEnum.Cancelled)
                                    {

                                        <span class="badge bg-secondary">Đã hủy</span>
                                    }
                                </td>
                                <td>
                                    <a href="~/Order/Details/@item.OrderID" class="btn btn-sm btn-outline-info rounded-pill">Chi tiết</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>