@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container py-5 text-center" style="min-height: 50vh;">
    <div class="mb-4" data-aos="zoom-in">
        <i class="fa-solid fa-circle-check text-success" style="font-size: 5rem;"></i>
    </div>
    
    <h2 class="fw-bold mb-3">Đặt hàng thành công!</h2>
    <p class="text-muted fs-5 mb-2">Cảm ơn bạn đã mua sắm tại LiteMart.</p>
    <p class="text-muted mb-4">Mã đơn hàng của bạn là: <strong class="fs-4 text-dark">#@ViewBag.OrderID</strong></p>
    
    <div class="d-flex justify-content-center gap-3">
        <a asp-controller="Order" asp-action="History" class="btn btn-outline-secondary px-4 py-2 fw-bold rounded-pill">
            <i class="fa-solid fa-clipboard-list me-2"></i> Xem lịch sử mua hàng
        </a>
        <a asp-controller="Product" asp-action="Index" class="btn btn-warning px-4 py-2 fw-bold text-dark rounded-pill">
            <i class="fa-solid fa-arrow-left me-2"></i> Tiếp tục mua sắm
        </a>
    </div>
</div>
