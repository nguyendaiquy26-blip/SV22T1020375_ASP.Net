@model IEnumerable<SV22T1020375.Models.Product>
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    /* 1. ANIMATION FADE-IN KHI PAGE LOAD */
    body {
        opacity: 0;
        animation: fadeInPage 0.8s ease forwards;
    }

    @@keyframes fadeInPage {
        to {
            opacity: 1;
        }
    }

    /* 2. CUSTOM BANNER SÁNG & TINH TẾ (PASTEL) */
    .sale-banner {
        background: linear-gradient(135deg, #f0f9ff, #cbebfe);
        border: 1px solid rgba(13, 110, 253, 0.1);
        color: #333 !important;
    }

        .sale-banner h1, .sale-banner p {
            color: #333 !important;
        }

    /* 3. CSS CHO SẢN PHẨM HOVER EFFECT */
    .product-card {
        transition: all 0.3s ease;
        border: 1px solid rgba(0,0,0,.03) !important;
        background-color: #fff;
    }

        .product-card:hover {
            transform: scale(1.03) translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,.08) !important;
            border-color: rgba(13, 110, 253, 0.2) !important;
        }

    .hover-white:hover {
        color: white !important;
    }

    /* 4. Tùy chỉnh input */
    .input-group-text {
        border-right: none !important;
    }

    .form-control:focus, .form-select:focus {
        box-shadow: none;
        border-color: #ced4da;
    }
</style>

<div class="p-5 mb-4 text-white rounded-3 shadow-sm position-relative overflow-hidden sale-banner">
    <div class="container-fluid py-3 position-relative" style="z-index: 2;">
        <h1 class="display-5 fw-bold"><i class="fa fa-bolt text-warning"></i> Siêu Sale Công Nghệ</h1>
        <p class="col-md-8 fs-4 mb-0">Săn deal giá sốc, hàng chính hãng, giao hàng siêu tốc tận nơi.</p>
    </div>
    <i class="fa fa-laptop position-absolute" style="font-size: 15rem; opacity: 0.05; right: 5%; top: -20%; color: #0d6efd;"></i>
</div>

<div class="card shadow-sm border-0 mb-4 rounded-3" style="background-color: #fff;">
    <div class="card-body p-3">
        <form action="/Home/Index" method="get" id="formSearch" class="row g-2 align-items-center">

            <div class="col-md-3">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0 text-muted"><i class="fa fa-search"></i></span>
                    <input type="text" class="form-control bg-light border-0" name="searchValue" value="@ViewBag.SearchValue" placeholder="Tìm kiếm sản phẩm...">
                </div>
            </div>

            <div class="col-md-3">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0 text-muted"><i class="fa fa-list"></i></span>
                    <select class="form-select bg-light border-0" name="categoryID">
                        <option value="0">-- Tất cả danh mục --</option>
                        @foreach (var item in SV22T1020375.BusinessLayers.CommonDataService.ListOfCategories())
                        {
                            if (ViewBag.CategoryID == item.CategoryID)
                            {
                                <option value="@item.CategoryID" selected>@item.CategoryName</option>
                            }
                            else
                            {
                                <option value="@item.CategoryID">@item.CategoryName</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0 text-muted"><i class="fa fa-money-bill-wave"></i></span>
                    <input type="number" class="form-control bg-light border-0" name="minPrice" value="@(ViewBag.MinPrice > 0 ? ViewBag.MinPrice : "")" placeholder="Giá từ">
                    <span class="input-group-text bg-light border-0 text-muted">-</span>
                    <input type="number" class="form-control bg-light border-0" name="maxPrice" value="@(ViewBag.MaxPrice > 0 ? ViewBag.MaxPrice : "")" placeholder="Đến">
                </div>
            </div>

            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-warning fw-bold w-100 shadow-sm text-dark">
                    <i class="fa fa-filter me-1"></i> Lọc
                </button>
                <a href="/Home/Index" class="btn btn-light shadow-sm" title="Xóa bộ lọc" data-bs-toggle="tooltip">
                    <i class="fa fa-redo text-secondary"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-end mb-4 pb-2 border-bottom">
        <h4 class="fw-bold mb-0 text-dark">Sản phẩm hôm nay</h4>
        <span class="text-muted small">@Model?.Count() sản phẩm được hiển thị</span>
    </div>

    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12 text-center py-5 w-100">
                <div class="bg-white p-5 rounded-3 shadow-sm border border-light">
                    <i class="fa fa-box-open fa-4x text-muted mb-3"></i>
                    <h5 class="text-secondary fw-bold">Rất tiếc! Không tìm thấy sản phẩm phù hợp.</h5>
                    <p class="text-muted">Vui lòng thử lại với từ khóa hoặc bộ lọc khác.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm product-card overflow-hidden">
                        @{
                            string imagePath = string.IsNullOrEmpty(item.Photo) ? "macbook.png" : item.Photo;
                        }
                        <div class="p-4 text-center position-relative" style="height: 240px; background-color: #fff;">
                            <img src="@Configuration["WebSiteUrl"]/images/products/@imagePath" class="img-fluid h-100" style="object-fit: contain;" alt="@item.ProductName" onerror="this.src='/images/nophoto.png'">
                        </div>
                        <div class="card-body d-flex flex-column pt-3" style="background-color: #fbfbfb;">
                            <h6 class="card-title text-dark fw-semibold" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 42px;" title="@item.ProductName">
                                @item.ProductName
                            </h6>
                            <h5 class="text-danger fw-bold mt-auto mb-3">@item.Price.ToString("N0") <span class="text-decoration-underline" style="font-size:14px;">đ</span></h5>

                            <a href="/Product/Details/@item.ProductID" class="btn btn-outline-primary btn-sm mt-auto w-100 rounded-pill fw-bold hover-white">
                                <i class="fa fa-cart-plus me-1"></i> Chọn mua
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-center mt-5 mb-4">
            <ul class="pagination shadow-sm">
                @{
                    int currentPage = ViewBag.CurrentPage;
                    int totalPages = ViewBag.TotalPages;

                    int window = 2;
                    int startPage = Math.Max(1, currentPage - window);
                    int endPage = Math.Min(totalPages, currentPage + window);

                    string searchParams = $"&searchValue={ViewBag.SearchValue}&categoryID={ViewBag.CategoryID}&minPrice={ViewBag.MinPrice}&maxPrice={ViewBag.MaxPrice}";
                }

                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link px-3" href="/Home/Index?page=@(currentPage - 1)@searchParams">
                        <i class="fa fa-angle-left"></i>
                    </a>
                </li>

                @if (startPage > 1)
                {
                    <li class="page-item"><a class="page-link" href="/Home/Index?page=1@searchParams">1</a></li>
                    @if (startPage > 2)
                    {
                        <li class="page-item disabled"><span class="page-link text-muted">...</span></li>
                    }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" href="/Home/Index?page=@i@searchParams">@i</a>
                    </li>
                }

                @if (endPage < totalPages)
                {
                    @if (endPage < totalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link text-muted">...</span></li>
                    }
                    <li class="page-item"><a class="page-link" href="/Home/Index?page=@totalPages@searchParams">@totalPages</a></li>
                }

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link px-3" href="/Home/Index?page=@(currentPage + 1)@searchParams">
                        <i class="fa fa-angle-right"></i>
                    </a>
                </li>
            </ul>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Bật Tooltip của Bootstrap cho nút Refresh bộ lọc
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        });
    </script>
}