@model IEnumerable<SV22T1020375.Shop.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Trang chủ</a></li>
            <li class="breadcrumb-item active fw-bold" style="color: var(--primary-color);" aria-current="page">Giỏ hàng</li>
        </ol>
    </nav>

    <h2 class="fw-bold mb-4">Giỏ hàng của bạn</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5 border rounded-4 bg-light shadow-sm" data-aos="zoom-in">
            <i class="fa-solid fa-cart-shopping mb-3" style="font-size: 5rem; color: #ddd;"></i>
            <h4 class="text-muted fw-bold">Giỏ hàng trống</h4>
            <p class="text-muted mb-4">Bạn chưa chọn mua sản phẩm nào.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-warning px-4 py-2 fw-bold text-dark rounded-pill">
                <i class="fa-solid fa-bag-shopping me-2"></i> Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8 mb-4">
                <div class="card shadow-sm border-0 rounded-4" data-aos="fade-right">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4 py-3 text-muted">Sản phẩm</th>
                                        <th class="text-center py-3 text-muted">Đơn giá</th>
                                        <th class="text-center py-3 text-muted" style="width: 140px;">Số lượng</th>
                                        <th class="text-end py-3 text-muted">Thành tiền</th>
                                        <th class="text-end pe-4 py-3 text-muted">Xóa</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <img src="@Configuration["WebSiteUrl"]/images/products/@item.Photo" width="60" class="img-fluid rounded me-3" alt="@item.ProductName" style="object-fit: cover;">
                                                    <div>
                                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductID" class="text-decoration-none text-dark fw-bold product-link">@item.ProductName</a>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center text-danger fw-bold">@item.SalePrice.ToString("N0") đ</td>
                                            <td class="text-center">
                                                <form asp-controller="Cart" asp-action="UpdateCart" method="post" class="d-inline">
                                                    <input type="hidden" name="productId" value="@item.ProductID" />
                                                    <div class="input-group input-group-sm mx-auto" style="width: 100px;">
                                                        <input type="number" name="quantity" class="form-control text-center" value="@item.Quantity" min="1" max="99" onchange="this.form.submit()">
                                                    </div>
                                                </form>
                                            </td>
                                            <td class="text-end fw-bold text-danger">@item.TotalPrice.ToString("N0") đ</td>
                                            <td class="text-end pe-4">
                                                <a asp-controller="Cart" asp-action="RemoveFromCart" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-danger shadow-sm rounded-circle" title="Xóa" onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này khỏi giỏ hàng?');">
                                                    <i class="fa-solid fa-xmark"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                
                <div class="d-flex justify-content-between mt-4">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary rounded-pill fw-bold px-4">
                        <i class="fa-solid fa-arrow-left me-2"></i> Tiếp tục mua sắm
                    </a>
                    <a asp-controller="Cart" asp-action="ClearCart" class="btn btn-outline-danger rounded-pill fw-bold px-4" onclick="return confirm('Bạn muốn xóa tất cả sản phẩm khỏi giỏ hàng?');">
                        <i class="fa-solid fa-trash me-2"></i> Xóa tất cả
                    </a>
                </div>
            </div>

            <div class="col-lg-4" data-aos="fade-left">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Tổng giỏ hàng</h5>
                        
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Tổng phụ</span>
                            <span class="fw-bold">@Model.Sum(x => x.TotalPrice).ToString("N0") đ</span>
                        </div>
                        
                        <div class="d-flex justify-content-between mb-4 pb-4 border-bottom">
                            <span class="text-muted">Phí giao hàng</span>
                            <span class="text-success fw-bold">Miễn phí</span>
                        </div>

                        <div class="d-flex justify-content-between mb-4">
                            <span class="fs-5 fw-bold">Tổng cộng</span>
                            <span class="fs-4 fw-bold text-danger">@Model.Sum(x => x.TotalPrice).ToString("N0") đ</span>
                        </div>

                        <a asp-controller="Order" asp-action="Checkout" class="btn btn-warning w-100 py-3 rounded-pill fw-bold fs-6 text-dark shadow-sm">
                            Tiến hành thanh toán <i class="fa-solid fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .product-link:hover {
        color: var(--primary-color) !important;
    }
</style>
