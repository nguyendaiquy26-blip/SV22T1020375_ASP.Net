@model IEnumerable<SV22T1020375.Models.CartItem>

@{
    ViewData["Title"] = "Thanh toán đơn hàng";
}

<h2>Xác nhận & Thanh toán</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <h4>Thông tin giao hàng</h4>
        <form action="~/Product/ProcessCheckout" method="post">
            <div class="form-group mb-3">
                <label>Tỉnh/Thành phố</label>
                <select name="deliveryProvince" class="form-select form-control" required>
                    <option value="">-- Vui lòng chọn Tỉnh/Thành phố --</option>

                    @if (ViewBag.Provinces != null)
                    {
                        foreach (var province in ViewBag.Provinces)
                        {
                            <option value="@province.ProvinceName">@province.ProvinceName</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group mb-3">
                <label>Địa chỉ chi tiết</label>
                <input type="text" name="deliveryAddress" class="form-control" required placeholder="VD: Số nhà, Tên đường..." />
            </div>

            <h4 class="mt-4">Phương thức thanh toán</h4>
            <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="paymentMethod" value="Direct" id="payDirect" checked>
                <label class="form-check-label" for="payDirect">
                    💵 Thanh toán khi nhận hàng (COD)
                </label>
            </div>
            <div class="form-check mb-4">
                <input class="form-check-input" type="radio" name="paymentMethod" value="VNPay" id="payVNPay">
                <label class="form-check-label" for="payVNPay">
                    💳 Thanh toán qua Ví VNPay / MoMo
                </label>
            </div>

            <button type="submit" class="btn btn-success btn-lg">Xác nhận đặt hàng</button>
            <a href="~/Product/ShoppingCart" class="btn btn-secondary btn-lg">Quay lại giỏ hàng</a>
        </form>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-info text-white">
                Tóm tắt đơn hàng
            </div>
            <div class="card-body">
                <table class="table">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ProductName (x @item.Quantity)</td>
                            <td class="text-end">@((item.Price * item.Quantity).ToString("N0")) đ</td>
                        </tr>
                    }
                </table>
                <hr />
                <h5 class="text-end text-danger">
                    Tổng tiền: @Model.Sum(m => m.Price * m.Quantity).ToString("N0") đ
                </h5>
            </div>
        </div>
    </div>
</div>