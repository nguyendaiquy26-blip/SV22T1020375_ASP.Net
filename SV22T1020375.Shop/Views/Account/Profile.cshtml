@model SV22T1020375.Models.Partner.Customer

@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="container py-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm border-0 rounded-4" data-aos="fade-right">
                <div class="card-body text-center p-4">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3 text-secondary" style="width: 100px; height: 100px; font-size: 3rem;">
                        <i class="fa-regular fa-user"></i>
                    </div>
                    <h5 class="fw-bold mb-1">@Model.CustomerName</h5>
                    <p class="text-muted small mb-3">@Model.Email</p>

                    <div class="list-group list-group-flush text-start">
                        <a asp-controller="Account" asp-action="Profile" class="list-group-item list-group-item-action active fw-bold border-0 bg-transparent" style="color: var(--primary-color);">
                            <i class="fa-regular fa-id-badge me-2"></i> Hồ sơ
                        </a>
                        <a asp-controller="Account" asp-action="ChangePassword" class="list-group-item list-group-item-action text-muted border-0">
                            <i class="fa-solid fa-lock me-2"></i> Đổi mật khẩu
                        </a>
                        <a asp-controller="Order" asp-action="History" class="list-group-item list-group-item-action text-muted border-0">
                            <i class="fa-solid fa-box-open me-2"></i> Đơn mua
                        </a>
                        <a asp-controller="Account" asp-action="Logout" class="list-group-item list-group-item-action text-danger border-0">
                            <i class="fa-solid fa-right-from-bracket me-2"></i> Đăng xuất
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card shadow-sm border-0 rounded-4" data-aos="fade-up">
                <div class="card-body p-4 p-md-5">
                    <h4 class="fw-bold mb-4">Hồ sơ của tôi</h4>
                    <p class="text-muted mb-4">Quản lý thông tin hồ sơ để bảo mật tài khoản</p>

                    @if (ViewBag.SuccessMessage != null)
                    {
                        <div class="alert alert-success">@ViewBag.SuccessMessage</div>
                    }

                    <form asp-controller="Account" asp-action="Profile" method="post">

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                @Html.ValidationSummary(false, "", new { @class = "text-danger mb-0" })
                            </div>
                        }

                        <input type="hidden" asp-for="IsLocked" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted">Họ và Tên (*)</label>
                                <input type="text" asp-for="CustomerName" class="form-control bg-light" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted">Tên giao dịch</label>
                                <input type="text" asp-for="ContactName" class="form-control bg-light">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted">Email (*)</label>
                            <input type="email" asp-for="Email" class="form-control bg-light" required readonly title="Không được phép đổi Email">
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted">Điện thoại</label>
                                <input type="text" asp-for="Phone" class="form-control bg-light">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted">Tỉnh thành (*)</label>
                                <select class="form-select bg-light" asp-for="Province" required>
                                    <option value="">-- Chọn Tỉnh/Thành --</option>
                                    @foreach (var item in SV22T1020375.BusinessLayers.CommonDataService.ListOfProvinces())
                                    {
                                        <option value="@item.ProvinceName">@item.ProvinceName</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted">Địa chỉ</label>
                            <input type="text" asp-for="Address" class="form-control bg-light">
                        </div>

                        <button type="submit" class="btn btn-warning px-5 py-2 fw-bold text-dark rounded-pill">
                            Lưu Thông Tin
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>